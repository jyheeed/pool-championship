# MongoDB (primary runtime database)
# Use MongoDB Atlas in production.
MONGODB_URI=mongodb://localhost:27017/pool-championship

# Admin Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-secret-key-here
ADMIN_USERNAME=admin
# Generate hash with: node -e "require('bcryptjs').hash('yourpassword',10).then(console.log)"
ADMIN_PASSWORD_HASH=$2a$10$...your-bcrypt-hash...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_TOURNAMENT_NAME=Tunisian Billiards Championship 2026
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Stream / Vision integration (Phase 1)
# Optional in development. In production, set this key in both services.
VISION_SERVICE_KEY=
NEXT_API_BASE_URL=http://localhost:3000
VISION_SERVICE_INTERNAL_URL=http://localhost:8010
VISION_MATCH_ID=
VISION_DISCIPLINE=8-ball
VISION_CAMERA_SOURCE=mock
VISION_CAMERA_FPS=12
VISION_MOTION_THRESHOLD=18
VISION_STABILIZING_THRESHOLD=8
VISION_STABLE_REQUIRED_FRAMES=15
VISION_STABLE_WINDOW_FRAMES=12
VISION_MISSING_CONFIRM_FRAMES=8
VISION_MISSING_CONFIDENCE_THRESHOLD=0.85
VISION_REVIEW_LOWER_CONFIDENCE_THRESHOLD=0.60
VISION_MOCK_DROP_EVERY_N_STABLE=3
VISION_MOCK_DROP_SEQUENCE=
VISION_MONGO_ENABLED=false
VISION_MONGO_URI=mongodb://localhost:27017
VISION_MONGO_DB_NAME=pool-championship
VISION_MONGO_EVENTS_COLLECTION=vision_events
VISION_MONGO_SNAPSHOTS_COLLECTION=vision_snapshots
